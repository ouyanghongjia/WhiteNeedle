{
  "name": "whiteneedle",
  "displayName": "WhiteNeedle",
  "description": "Remote iOS debugging powered by WhiteNeedle Engine — LAN discovery, script push, ObjC runtime inspection",
  "version": "0.1.0",
  "publisher": "whiteneedle",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/WhiteNeedle"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "ios",
    "debugging",
    "objective-c",
    "runtime",
    "hook",
    "reverse-engineering",
    "mobile",
    "framework",
    "javascript",
    "injection"
  ],
  "categories": [
    "Debuggers",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onView:whiteneedle-devices",
    "onCommand:whiteneedle.connectByIP",
    "onCommand:whiteneedle.connectDevice",
    "onCommand:whiteneedle.refreshDevices",
    "onCommand:whiteneedle.pushScript",
    "onCommand:whiteneedle.stopScript",
    "onCommand:whiteneedle.disconnectDevice",
    "onCommand:whiteneedle.newScript",
    "onCommand:whiteneedle.evaluate",
    "onCommand:whiteneedle.listHooks",
    "onCommand:whiteneedle.openCookies",
    "onCommand:whiteneedle.openUserDefaults",
    "onCommand:whiteneedle.openSandbox",
    "onCommand:whiteneedle.openSQLite",
    "onCommand:whiteneedle.openObjC",
    "onCommand:whiteneedle.openNetwork",
    "onCommand:whiteneedle.openMockRules",
    "onCommand:whiteneedle.openViewHierarchy",
    "onCommand:whiteneedle.openHostMapping",
    "onCommand:whiteneedle.startProxy",
    "onCommand:whiteneedle.stopProxy",
    "onCommand:whiteneedle.openSnippets",
    "onCommand:whiteneedle.openApiDocs",
    "onCommand:whiteneedle.syncTeamSnippets",
    "onCommand:whiteneedle.openLeakDetector",
    "onCommand:whiteneedle.openRetainGraph",
    "onCommand:whiteneedle.openPanelsMenu",
    "onCommand:whiteneedle.toggleProxy",
    "onCommand:whiteneedle.installModule",
    "onCommand:whiteneedle.uninstallModule",
    "onCommand:whiteneedle.refreshModules",
    "onView:whiteneedle-modules",
    "onDebugResolve:whiteneedle"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "whiteneedle",
          "title": "WhiteNeedle",
          "icon": "resources/icon-needle.svg"
        }
      ]
    },
    "views": {
      "whiteneedle": [
        {
          "id": "whiteneedle-devices",
          "name": "Devices"
        },
        {
          "id": "whiteneedle-scripts",
          "name": "Scripts"
        },
        {
          "id": "whiteneedle-modules",
          "name": "Installed Modules"
        }
      ]
    },
    "submenus": [],
    "commands": [
      {
        "command": "whiteneedle.refreshDevices",
        "title": "Refresh Devices",
        "icon": "$(refresh)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.connectDevice",
        "title": "Connect to Device",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.connectByIP",
        "title": "Connect by IP Address",
        "icon": "$(plug)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.disconnectDevice",
        "title": "Disconnect Device",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.pushScript",
        "title": "Push & Run Script",
        "icon": "$(play)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.stopScript",
        "title": "Stop Script",
        "icon": "$(debug-stop)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.newScript",
        "title": "New WhiteNeedle Script",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openCookies",
        "title": "Cookies",
        "icon": "$(database)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openUserDefaults",
        "title": "UserDefaults",
        "icon": "$(settings-gear)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openSandbox",
        "title": "Sandbox Files",
        "icon": "$(folder-opened)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openSQLite",
        "title": "SQLite Browser",
        "icon": "$(database)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openObjC",
        "title": "ObjC Runtime",
        "icon": "$(symbol-class)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.statusBarAction",
        "title": "Connection Status",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openLogs",
        "title": "Structured Logs",
        "icon": "$(output)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openHooks",
        "title": "Hook Manager",
        "icon": "$(debug-breakpoint-function)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openNetwork",
        "title": "Network Monitor",
        "icon": "$(globe)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openMockRules",
        "title": "HTTP Mock Rules",
        "icon": "$(replace)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openViewHierarchy",
        "title": "View Hierarchy Inspector",
        "icon": "$(layers)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openHostMapping",
        "title": "Host Mapping (SwitchHosts)",
        "icon": "$(arrow-swap)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.startProxy",
        "title": "Start Proxy Server",
        "icon": "$(radio-tower)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.stopProxy",
        "title": "Stop Proxy Server",
        "icon": "$(circle-slash)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.toggleProxy",
        "title": "Toggle Proxy Server",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.evaluate",
        "title": "Evaluate JavaScript Expression",
        "icon": "$(terminal)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.listHooks",
        "title": "List Active Hooks",
        "icon": "$(list-unordered)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openSnippets",
        "title": "Script Snippets",
        "icon": "$(library)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openApiDocs",
        "title": "API Documentation",
        "icon": "$(book)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.syncTeamSnippets",
        "title": "Sync Team Script Snippets",
        "icon": "$(sync)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openLeakDetector",
        "title": "Leak Detector",
        "icon": "$(search-fuzzy)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openRetainGraph",
        "title": "Retain Graph",
        "icon": "$(type-hierarchy)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.installModule",
        "title": "Install JS Module",
        "icon": "$(add)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.uninstallModule",
        "title": "Uninstall Module",
        "icon": "$(trash)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.refreshModules",
        "title": "Refresh Modules",
        "icon": "$(refresh)",
        "category": "WhiteNeedle"
      },
      {
        "command": "whiteneedle.openPanelsMenu",
        "title": "Panels",
        "icon": "$(layout-panel)",
        "category": "WhiteNeedle"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "whiteneedle.refreshDevices",
          "when": "view == whiteneedle-devices",
          "group": "navigation@1"
        },
        {
          "command": "whiteneedle.connectByIP",
          "when": "view == whiteneedle-devices",
          "group": "navigation@2"
        },
        {
          "command": "whiteneedle.openPanelsMenu",
          "when": "view == whiteneedle-devices",
          "group": "navigation@3"
        },
        {
          "command": "whiteneedle.installModule",
          "when": "view == whiteneedle-modules",
          "group": "navigation@1"
        },
        {
          "command": "whiteneedle.refreshModules",
          "when": "view == whiteneedle-modules",
          "group": "navigation@2"
        },
        {
          "command": "whiteneedle.pushScript",
          "when": "view == whiteneedle-scripts",
          "group": "navigation@1"
        },
        {
          "command": "whiteneedle.stopScript",
          "when": "view == whiteneedle-scripts",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "whiteneedle.uninstallModule",
          "when": "view == whiteneedle-modules && viewItem == installedModule",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "whiteneedle.pushScript",
          "when": "resourceExtname == .js",
          "group": "navigation"
        },
        {
          "command": "whiteneedle.stopScript",
          "when": "resourceExtname == .js",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "whiteneedle.pushScript",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus && resourceExtname == .js"
      }
    ],
    "debuggers": [
      {
        "type": "whiteneedle",
        "label": "WhiteNeedle",
        "languages": [
          "javascript"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "host"
            ],
            "properties": {
              "host": {
                "type": "string",
                "description": "Target device IP address (use 127.0.0.1 for USB)",
                "default": "127.0.0.1"
              },
              "inspectorPort": {
                "type": "number",
                "description": "ios_webkit_debug_proxy 本地端口（默认 9222）",
                "default": 9222
              },
              "script": {
                "type": "string",
                "description": "Optional: script path for reference; load script on device via Push & Run before debugging",
                "default": "${file}"
              },
              "targetTitle": {
                "type": "string",
                "description": "多个调试目标时始终弹出选择列表。填写时仅将同名目标排在列表最前，不会自动连接（避免误选 JSContext 而跳过 WKWebView）",
                "default": ""
              },
              "webkitDeviceUdid": {
                "type": "string",
                "description": "可选：仅为此 UDID 启动 ios_webkit_debug_proxy（-u），避免多设备时 9222/9223 抢端口与反复断连。留空则使用设置 whiteneedle.webkitDeviceUdid，再留空则代理所有已连接设备",
                "default": ""
              },
              "verbose": {
                "type": "boolean",
                "description": "在 Debug Console 输出完整 CDP/WIP 协议日志（开发插件时使用）",
                "default": false
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "WhiteNeedle: Debug Script",
            "description": "通过 ios_webkit_debug_proxy 调试 JSContext / WKWebView",
            "body": {
              "type": "whiteneedle",
              "request": "launch",
              "name": "WhiteNeedle: Debug",
              "host": "127.0.0.1",
              "inspectorPort": 9222,
              "script": "^\"\\${file}\""
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "WhiteNeedle",
      "properties": {
        "whiteneedle.autoReload": {
          "type": "boolean",
          "default": true,
          "description": "Auto-reload script on save"
        },
        "whiteneedle.scriptMode": {
          "type": "string",
          "enum": ["single", "project"],
          "default": "single",
          "enumDescriptions": [
            "Single-file mode: wraps code in IIFE, reuses existing JSContext (fast)",
            "Project mode: creates fresh JSContext, pushes local require() dependencies, replays panel hooks"
          ],
          "description": "Script execution mode — 'single' for quick single-file iteration, 'project' for multi-file projects with clean JSContext"
        },
        "whiteneedle.enginePort": {
          "type": "number",
          "default": 27042,
          "description": "WhiteNeedle TCP engine port on device (JSON-RPC; shown for reference when connecting by IP)"
        },
        "whiteneedle.inspectorPort": {
          "type": "number",
          "default": 9222,
          "description": "ios_webkit_debug_proxy 本地端口（默认 9222，通常无需修改）"
        },
        "whiteneedle.webkitDeviceUdid": {
          "type": "string",
          "default": "",
          "description": "仅将 Web Inspector 代理到此 iOS 设备的 UDID（ios_webkit_debug_proxy -u）。多机 USB 同时连接时可避免非目标机占用 9222 或频繁 Connected/Disconnected。留空表示代理所有设备（默认行为）。可用 idevice_id -l 或 Xcode 设备信息查看 UDID"
        },
        "whiteneedle.deviceHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Device IP for Inspector/DAP (updated automatically when you connect in the Devices view)"
        },
        "whiteneedle.lastBundleId": {
          "type": "string",
          "default": "",
          "description": "Bundle ID of last connected device (auto-updated, used for device identity matching)"
        },
        "whiteneedle.lastDeviceName": {
          "type": "string",
          "default": "",
          "description": "Name of last connected device (auto-updated, used for device identity matching)"
        },
        "whiteneedle.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect to the last device when the extension restarts and the device is found via Bonjour or direct TCP probe"
        },
        "whiteneedle.proxyPort": {
          "type": "number",
          "default": 8899,
          "description": "HTTP/HTTPS proxy port for host mapping. Set your iOS device's HTTP proxy to this Mac's IP and this port."
        },
        "whiteneedle.snippets.teamFile": {
          "type": "string",
          "default": ".whiteneedle/team-snippets.json",
          "description": "Path to the team snippets JSON file, relative to each workspace folder root. Git-commit this file so the team can sync after pull."
        },
        "whiteneedle.favoritePanels": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "常用面板列表（命令 ID 数组），排列在 Panels 菜单顶部。通过 Panels → 管理常用面板 进行配置"
        }
      }
    }
  },
  "scripts": {
    "sync-bundled-docs": "node scripts/sync-bundled-docs.mjs",
    "vscode:prepublish": "npm run sync-bundled-docs && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-inspector": "node scripts/check-inspector.mjs"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "bonjour-service": "^1.2.0",
    "marked": "^12.0.2",
    "ws": "^8.20.0"
  }
}
