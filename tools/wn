#!/bin/bash
set -euo pipefail

# ============================================================================
# wn — WhiteNeedle CLI
#
# One-command integration, removal, and resign for iOS projects.
#
# Usage:
#   wn integrate <project-dir>    Integrate WhiteNeedle via CocoaPods
#   wn remove <project-dir>       Remove WhiteNeedle integration
#   wn status <project-dir>       Check integration status
#   wn build                      Build WhiteNeedle framework (full dist)
#   wn update [opts] [project]    Recompile + install (framework/extension)
#   wn resign <ipa> [-o output]   Inject WhiteNeedle into IPA and re-sign
#   wn help                       Show this help
# ============================================================================

WN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WN_DIST="$WN_ROOT/dist"
WN_COCOAPODS="$WN_DIST/cocoapods/WhiteNeedle"
WN_FRAMEWORK="$WN_DIST/WhiteNeedle.framework"
WN_CONFIG_DIR="$HOME/.whiteneedle"
WN_RESIGN_CONF="$WN_CONFIG_DIR/resign.conf"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

log()  { echo -e "${GREEN}[wn]${NC} $*"; }
warn() { echo -e "${YELLOW}[wn]${NC} $*" >&2; }
err()  { echo -e "${RED}[wn]${NC} $*" >&2; exit 1; }
info() { echo -e "${CYAN}[wn]${NC} $*"; }

# Sentinel markers for Podfile injection
SENTINEL_BEGIN="# >>> WhiteNeedle (managed by wn CLI) <<<"
SENTINEL_END="# >>> End WhiteNeedle <<<"
HOOK_SENTINEL_BEGIN="# >>> WhiteNeedle Hook <<<"
HOOK_SENTINEL_END="# >>> End WhiteNeedle Hook <<<"
FUNC_SENTINEL_BEGIN="# >>> WhiteNeedle Function (do not edit) <<<"
FUNC_SENTINEL_END="# >>> End WhiteNeedle Function <<<"

# ============================================================================
# Helpers
# ============================================================================

ensure_framework() {
    if [[ -d "$WN_FRAMEWORK" && -f "$WN_FRAMEWORK/WhiteNeedle" ]]; then
        log "Framework ready: $WN_FRAMEWORK"
        return 0
    fi
    info "Framework not found or outdated, building..."
    cmd_build
}

find_podfile() {
    local dir="$1"
    if [[ -f "$dir/Podfile" ]]; then
        echo "$dir/Podfile"
    else
        err "Podfile not found in: $dir"
    fi
}

podfile_has_whiteneedle() {
    local podfile="$1"
    grep -q "$SENTINEL_BEGIN" "$podfile" 2>/dev/null
}

ensure_config_dir() {
    mkdir -p "$WN_CONFIG_DIR"
}

# ============================================================================
# wn build
# ============================================================================

cmd_build() {
    info "Building WhiteNeedle distribution..."
    "$WN_ROOT/build-dist.sh" --skip-vsix
    log "Build complete."
}

# ============================================================================
# wn update [options] [project-dir]
#
# Recompile & install WhiteNeedle components.
#   No flags   = update everything (framework + vsix)
#   --ios      = framework only (compile + pod refresh)
#   --ext      = VS Code / Cursor extension only (build + install vsix)
#   --vscode   = install vsix to VS Code only
#   --cursor   = install vsix to Cursor only
# ============================================================================

cmd_update() {
    local do_ios=false
    local do_ext=false
    local ext_target="auto"   # auto | vscode | cursor
    local project_dir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ios)     do_ios=true; shift ;;
            --ext)     do_ext=true; shift ;;
            --vscode)  do_ext=true; ext_target="vscode"; shift ;;
            --cursor)  do_ext=true; ext_target="cursor"; shift ;;
            -h|--help) update_usage ;;
            -*)        err "Unknown update option: $1. Run 'wn update --help'" ;;
            *)
                if [[ -z "$project_dir" ]]; then
                    project_dir="$1"; shift
                else
                    err "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    # Default: update everything
    if [[ "$do_ios" == false && "$do_ext" == false ]]; then
        do_ios=true
        do_ext=true
    fi

    # ── iOS framework ──
    if [[ "$do_ios" == true ]]; then
        step_build_framework
        step_refresh_cocoapods_pod

        if [[ -n "$project_dir" ]]; then
            project_dir="$(cd "$project_dir" 2>/dev/null && pwd)" || err "Directory not found: $project_dir"
            step_pod_update "$project_dir"
        else
            local detected
            detected=$(detect_integrated_project)
            if [[ -n "$detected" ]]; then
                step_pod_update "$detected"
            else
                log "Framework updated. Specify a project dir to also refresh pods."
            fi
        fi
    fi

    # ── VS Code / Cursor extension ──
    if [[ "$do_ext" == true ]]; then
        step_build_vsix
        step_install_vsix "$ext_target"
    fi
}

update_usage() {
    cat <<EOF
Usage: wn update [options] [project-dir]

Recompile and install WhiteNeedle components.

${BOLD}Options:${NC}
  --ios              Update iOS framework only (compile + refresh pods)
  --ext              Update VS Code / Cursor extension only (build + install)
  --vscode           Build and install extension to VS Code only
  --cursor           Build and install extension to Cursor only
  -h, --help         Show this help

${BOLD}No flags = update everything (framework + extension).${NC}

${BOLD}Examples:${NC}
  wn update                              # Full update: framework + extension
  wn update ~/Projects/MyApp             # Full update + refresh pods in project
  wn update --ios ~/Projects/MyApp       # Framework only + refresh pods
  wn update --ext                        # Extension only (auto-detect IDEs)
  wn update --cursor                     # Extension to Cursor only
  wn update --vscode                     # Extension to VS Code only
EOF
    exit 0
}

# ── Framework build ──────────────────────────────────────────────────────────

step_build_framework() {
    local fw_src="$WN_ROOT/ios-dylib"
    local fw_out="$fw_src/build/WhiteNeedle.framework"

    info "Compiling WhiteNeedle.framework (arm64, iOS 15+)..."
    (cd "$fw_src" && make)

    [[ -d "$fw_out" ]] || err "Framework build failed"
    log "Framework compiled: $fw_out"

    mkdir -p "$WN_DIST"
    rm -rf "$WN_FRAMEWORK"
    cp -R "$fw_out" "$WN_FRAMEWORK"
}

step_refresh_cocoapods_pod() {
    info "Updating CocoaPods pod distribution..."
    mkdir -p "$WN_COCOAPODS"

    rm -rf "$WN_COCOAPODS/WhiteNeedle.framework"
    cp -R "$WN_FRAMEWORK" "$WN_COCOAPODS/WhiteNeedle.framework"

    mkdir -p "$WN_COCOAPODS/BuiltinModules"
    rm -f "$WN_COCOAPODS/BuiltinModules/"*.js
    cp "$WN_ROOT/ios-dylib/WhiteNeedle/BuiltinModules/"*.js "$WN_COCOAPODS/BuiltinModules/"

    if [[ ! -f "$WN_COCOAPODS/WhiteNeedle.podspec" ]]; then
        warn "podspec missing — run 'wn build' for a full dist first"
    fi

    log "Pod distribution refreshed: $WN_COCOAPODS"
}

step_pod_update() {
    local project_dir="$1"
    local podfile
    podfile=$(find_podfile "$project_dir")

    if ! podfile_has_whiteneedle "$podfile"; then
        warn "WhiteNeedle not integrated in $project_dir (run: wn integrate)"
        return 1
    fi

    info "Updating pods in: $project_dir"
    (cd "$project_dir" && pod install)

    echo ""
    log "============================================"
    log "  WhiteNeedle iOS plugin updated!"
    log "============================================"
    echo ""
    echo "  Project: $project_dir"
    echo "  Clean build in Xcode (Cmd+Shift+K) recommended."
    echo ""
}

detect_integrated_project() {
    local candidate=""
    if [[ -f "./Podfile" ]] && grep -q "$SENTINEL_BEGIN" "./Podfile" 2>/dev/null; then
        candidate="$(pwd)"
    fi
    echo "$candidate"
}

# ── VSIX build & install ────────────────────────────────────────────────────

step_build_vsix() {
    local ext_dir="$WN_ROOT/vscode-extension"
    local vsix_path="$WN_DIST/WhiteNeedle.vsix"

    info "Building WhiteNeedle VS Code extension..."
    mkdir -p "$WN_DIST"

    (
        cd "$ext_dir"
        npm install --no-audit --no-fund 2>&1 | tail -1
        npm run compile

        cp -f "$WN_ROOT/LICENSE" "$ext_dir/LICENSE" 2>/dev/null || true

        if command -v vsce >/dev/null 2>&1; then
            echo 'y' | vsce package -o "$vsix_path"
        else
            echo 'y' | npx --yes @vscode/vsce package -o "$vsix_path"
        fi
    )

    [[ -f "$vsix_path" ]] || err "VSIX packaging failed"
    log "VSIX built: $vsix_path"
}

step_install_vsix() {
    local target="$1"
    local vsix_path="$WN_DIST/WhiteNeedle.vsix"
    [[ -f "$vsix_path" ]] || err "VSIX not found at $vsix_path — build first"

    local installed=false

    # Determine which IDEs to install to
    local install_vscode=false
    local install_cursor=false

    case "$target" in
        vscode)
            install_vscode=true
            ;;
        cursor)
            install_cursor=true
            ;;
        auto)
            # Auto-detect: install to all available IDEs
            if command -v cursor >/dev/null 2>&1; then
                install_cursor=true
            fi
            if command -v code >/dev/null 2>&1; then
                install_vscode=true
            fi
            ;;
    esac

    if [[ "$install_cursor" == true ]]; then
        if command -v cursor >/dev/null 2>&1; then
            info "Installing extension to Cursor..."
            if cursor --install-extension "$vsix_path" --force 2>&1; then
                log "Installed to Cursor ✓"
                installed=true
            else
                warn "Failed to install to Cursor"
            fi
        else
            warn "Cursor CLI not found (install: Cursor → Cmd+Shift+P → 'Install cursor command')"
        fi
    fi

    if [[ "$install_vscode" == true ]]; then
        if command -v code >/dev/null 2>&1; then
            info "Installing extension to VS Code..."
            if code --install-extension "$vsix_path" --force 2>&1; then
                log "Installed to VS Code ✓"
                installed=true
            else
                warn "Failed to install to VS Code"
            fi
        else
            warn "VS Code CLI not found (install: VS Code → Cmd+Shift+P → 'Install code command')"
        fi
    fi

    if [[ "$installed" == false ]]; then
        warn "No IDE detected. Install manually:"
        echo "  code --install-extension $vsix_path"
        echo "  cursor --install-extension $vsix_path"
        return 1
    fi

    echo ""
    log "============================================"
    log "  WhiteNeedle extension updated!"
    log "============================================"
    echo ""
    echo "  Reload window (Cmd+Shift+P → 'Reload Window') to activate."
    echo ""
}

# ============================================================================
# wn status <project-dir>
# ============================================================================

cmd_status() {
    local project_dir="${1:-.}"
    project_dir="$(cd "$project_dir" 2>/dev/null && pwd)" || err "Directory not found: $1"
    local podfile
    podfile=$(find_podfile "$project_dir")

    echo -e "${BOLD}WhiteNeedle Integration Status${NC}"
    echo "  Project: $project_dir"
    echo ""

    if podfile_has_whiteneedle "$podfile"; then
        echo -e "  Status: ${GREEN}Integrated${NC}"
        local pod_path
        pod_path=$(grep "pod 'WhiteNeedle'" "$podfile" | grep -oE ":path => '[^']+'" | sed "s/:path => '//;s/'//")
        echo "  Pod path: $pod_path"
    else
        echo -e "  Status: ${YELLOW}Not integrated${NC}"
    fi

    echo ""
    if [[ -d "$WN_FRAMEWORK" ]]; then
        echo -e "  Framework: ${GREEN}Built${NC} ($WN_FRAMEWORK)"
    else
        echo -e "  Framework: ${YELLOW}Not built${NC} (run: wn build)"
    fi
}

# ============================================================================
# wn integrate <project-dir>
# ============================================================================

cmd_integrate() {
    local project_dir="${1:-.}"
    project_dir="$(cd "$project_dir" 2>/dev/null && pwd)" || err "Directory not found: $1"

    info "Integrating WhiteNeedle into: $project_dir"

    # Step 1: Ensure framework is built
    ensure_framework

    # Step 2: Find Podfile
    local podfile
    podfile=$(find_podfile "$project_dir")

    # Step 3: Check if already integrated
    if podfile_has_whiteneedle "$podfile"; then
        log "WhiteNeedle is already integrated in this project."
        log "To re-integrate, run: wn remove \"$project_dir\" && wn integrate \"$project_dir\""
        return 0
    fi

    # Step 4: Backup Podfile
    cp "$podfile" "${podfile}.wn-backup"
    log "Backed up Podfile → Podfile.wn-backup"

    # Step 5: Inject pod reference into Podfile
    inject_pod_reference "$podfile"

    # Step 6: Inject post_install hook
    inject_post_install_hook "$podfile"

    # Step 7: Append helper function
    inject_helper_function "$podfile"

    # Step 8: Remove old require_relative for cocoapods_hook if present
    remove_old_hook_require "$podfile"

    # Step 9: Run pod install
    info "Running pod install..."
    (cd "$project_dir" && pod install)

    echo ""
    log "============================================"
    log "  WhiteNeedle integrated successfully!"
    log "============================================"
    echo ""
    echo "  Project: $project_dir"
    echo "  Pod path: $WN_COCOAPODS"
    echo ""
    echo "  Build your project in Xcode as usual."
    echo "  WhiteNeedle will auto-inject network permissions."
    echo ""
}

inject_pod_reference() {
    local podfile="$1"
    local pod_line="  pod 'WhiteNeedle', :path => '$WN_COCOAPODS'"

    # First, remove any existing pod 'WhiteNeedle' lines (old manual references)
    local tmpfile
    tmpfile=$(mktemp)
    grep -v "pod ['\"]WhiteNeedle['\"]" "$podfile" > "$tmpfile" || true
    mv "$tmpfile" "$podfile"

    # Now inject after the first 'target ... do' line
    tmpfile=$(mktemp)
    local injected=false

    while IFS= read -r line; do
        echo "$line" >> "$tmpfile"
        if [[ "$injected" == false ]] && echo "$line" | grep -qE "^target .* do"; then
            echo "" >> "$tmpfile"
            echo "$SENTINEL_BEGIN" >> "$tmpfile"
            echo "$pod_line" >> "$tmpfile"
            echo "$SENTINEL_END" >> "$tmpfile"
            injected=true
        fi
    done < "$podfile"

    if [[ "$injected" == false ]]; then
        err "Could not find 'target ... do' block in Podfile"
    fi

    mv "$tmpfile" "$podfile"
    log "Added pod 'WhiteNeedle' reference"
}

inject_post_install_hook() {
    local podfile="$1"
    local hook_call="    whiteneedle_inject_permissions(installer)"

    # Check if post_install already exists
    if grep -qE "^post_install " "$podfile"; then
        # Insert our hook call at the beginning of the existing post_install block
        local tmpfile
        tmpfile=$(mktemp)
        local injected=false

        while IFS= read -r line; do
            echo "$line" >> "$tmpfile"
            if [[ "$injected" == false ]] && echo "$line" | grep -qE "^post_install "; then
                echo "$HOOK_SENTINEL_BEGIN" >> "$tmpfile"
                echo "$hook_call" >> "$tmpfile"
                echo "$HOOK_SENTINEL_END" >> "$tmpfile"
                injected=true
            fi
        done < "$podfile"

        mv "$tmpfile" "$podfile"
    else
        # Create a new post_install block
        cat >> "$podfile" <<EOF

post_install do |installer|
$HOOK_SENTINEL_BEGIN
$hook_call
$HOOK_SENTINEL_END
end
EOF
    fi
    log "Added post_install hook"
}

inject_helper_function() {
    local podfile="$1"

    cat >> "$podfile" <<'RUBY'

# >>> WhiteNeedle Function (do not edit) <<<
require 'xcodeproj'

def whiteneedle_inject_permissions(installer)
  phase_name = '[WhiteNeedle] Inject Network Permissions'
  script = <<~'SH'
    PLIST="${BUILT_PRODUCTS_DIR}/${INFOPLIST_PATH}"
    [ -f "$PLIST" ] || { echo "warning: [WhiteNeedle] Info.plist not found, skipping."; exit 0; }
    BUDDY=/usr/libexec/PlistBuddy
    CHANGED=0
    if ! $BUDDY -c "Print :NSBonjourServices" "$PLIST" 2>/dev/null | grep -q "_whiteneedle._tcp"; then
      $BUDDY -c "Add :NSBonjourServices array" "$PLIST" 2>/dev/null || true
      $BUDDY -c "Add :NSBonjourServices: string _whiteneedle._tcp" "$PLIST"
      CHANGED=1
    fi
    if ! $BUDDY -c "Print :NSLocalNetworkUsageDescription" "$PLIST" 2>/dev/null >/dev/null; then
      $BUDDY -c "Add :NSLocalNetworkUsageDescription string WhiteNeedle uses the local network for remote debugging." "$PLIST"
      CHANGED=1
    fi
    if [ "$CHANGED" -eq 1 ]; then
      plutil -convert binary1 "$PLIST"
      echo "note: [WhiteNeedle] Injected Bonjour permissions into Info.plist"
    fi
  SH

  count = 0
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_targets.each do |user_target|
      next unless user_target.product_type == 'com.apple.product-type.application'
      user_target.shell_script_build_phases
                 .select { |p| p.name == phase_name }
                 .each { |p| user_target.build_phases.delete(p) }
      phase = user_target.new_shell_script_build_phase(phase_name)
      phase.shell_script = script
      phase.shell_path = '/bin/sh'
      copy_res = user_target.build_phases.find { |p| p.is_a?(Xcodeproj::Project::Object::PBXResourcesBuildPhase) }
      if copy_res
        idx = user_target.build_phases.index(copy_res)
        user_target.build_phases.move(phase, idx + 1)
      end
      count += 1
    end
    aggregate_target.user_project.save
  end
  Pod::UI.puts "[WhiteNeedle] Added network permission build phase to #{count} app target(s)."
end
# >>> End WhiteNeedle Function <<<
RUBY
    log "Added helper function definition"
}

remove_old_hook_require() {
    local podfile="$1"
    # Remove old require_relative lines for cocoapods_hook
    if grep -q "require_relative.*cocoapods_hook" "$podfile"; then
        local tmpfile
        tmpfile=$(mktemp)
        grep -v "require_relative.*cocoapods_hook" "$podfile" > "$tmpfile"
        mv "$tmpfile" "$podfile"
        log "Removed old require_relative for cocoapods_hook"
    fi
    # Remove old standalone whiteneedle_inject_permissions call (outside our sentinels)
    # that might exist from manual setup - only if it's NOT inside our sentinel block
    if grep -q "whiteneedle_inject_permissions" "$podfile"; then
        local tmpfile
        tmpfile=$(mktemp)
        local in_sentinel=false
        while IFS= read -r line; do
            if echo "$line" | grep -q "$HOOK_SENTINEL_BEGIN"; then
                in_sentinel=true
            fi
            if echo "$line" | grep -q "$HOOK_SENTINEL_END"; then
                in_sentinel=false
                echo "$line" >> "$tmpfile"
                continue
            fi
            if [[ "$in_sentinel" == false ]] && echo "$line" | grep -q "whiteneedle_inject_permissions" && ! echo "$line" | grep -q "^def "; then
                # Skip old standalone call outside sentinel
                continue
            fi
            echo "$line" >> "$tmpfile"
        done < "$podfile"
        mv "$tmpfile" "$podfile"
    fi
}

# ============================================================================
# wn remove <project-dir>
# ============================================================================

cmd_remove() {
    local project_dir="${1:-.}"
    project_dir="$(cd "$project_dir" 2>/dev/null && pwd)" || err "Directory not found: $1"

    local podfile
    podfile=$(find_podfile "$project_dir")

    if ! podfile_has_whiteneedle "$podfile"; then
        log "WhiteNeedle is not integrated in this project."
        return 0
    fi

    info "Removing WhiteNeedle from: $project_dir"

    # Backup
    cp "$podfile" "${podfile}.wn-backup"

    # Remove all sentinel-marked blocks
    local tmpfile
    tmpfile=$(mktemp)
    local skip=false

    while IFS= read -r line; do
        if echo "$line" | grep -qF "$SENTINEL_BEGIN" || \
           echo "$line" | grep -qF "$HOOK_SENTINEL_BEGIN" || \
           echo "$line" | grep -qF "$FUNC_SENTINEL_BEGIN"; then
            skip=true
            continue
        fi
        if echo "$line" | grep -qF "$SENTINEL_END" || \
           echo "$line" | grep -qF "$HOOK_SENTINEL_END" || \
           echo "$line" | grep -qF "$FUNC_SENTINEL_END"; then
            skip=false
            continue
        fi
        if [[ "$skip" == false ]]; then
            echo "$line" >> "$tmpfile"
        fi
    done < "$podfile"

    mv "$tmpfile" "$podfile"

    # Clean up empty post_install block if we left one
    local tmpfile2
    tmpfile2=$(mktemp)
    local in_post_install=false
    local post_install_lines=()
    local post_install_empty=true

    while IFS= read -r line; do
        if echo "$line" | grep -qE "^post_install "; then
            in_post_install=true
            post_install_lines=("$line")
            post_install_empty=true
            continue
        fi
        if [[ "$in_post_install" == true ]]; then
            post_install_lines+=("$line")
            if echo "$line" | grep -qE "^end$"; then
                in_post_install=false
                if [[ "$post_install_empty" == true ]]; then
                    # Skip the empty post_install block entirely
                    :
                else
                    for pl in "${post_install_lines[@]}"; do
                        echo "$pl" >> "$tmpfile2"
                    done
                fi
                continue
            fi
            # Check if line has content (not blank)
            local trimmed
            trimmed=$(echo "$line" | sed 's/^[[:space:]]*//')
            if [[ -n "$trimmed" ]]; then
                post_install_empty=false
            fi
            continue
        fi
        echo "$line" >> "$tmpfile2"
    done < "$podfile"

    mv "$tmpfile2" "$podfile"

    # Remove trailing blank lines
    sed -i '' -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$podfile" 2>/dev/null || true

    log "Removed WhiteNeedle from Podfile"

    # Run pod install
    info "Running pod install..."
    (cd "$project_dir" && pod install)

    log "WhiteNeedle removed successfully."
}

# ============================================================================
# wn resign <ipa> [-o output] [-c cert] [-p profile] [-b bundle-id]
# ============================================================================

cmd_resign() {
    local ipa_path=""
    local output_path=""
    local cert=""
    local profile=""
    local bundle_id=""
    local keep_extensions=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output)   output_path="$2"; shift 2 ;;
            -c|--cert)     cert="$2"; shift 2 ;;
            -p|--profile)  profile="$2"; shift 2 ;;
            -b|--bundle-id) bundle_id="$2"; shift 2 ;;
            -e|--keep-extensions) keep_extensions=true; shift ;;
            -h|--help)     resign_usage ;;
            -*)            err "Unknown resign option: $1" ;;
            *)
                if [[ -z "$ipa_path" ]]; then
                    ipa_path="$1"; shift
                else
                    err "Unexpected argument: $1"
                fi
                ;;
        esac
    done

    [[ -n "$ipa_path" ]] || err "Missing IPA path. Usage: wn resign <ipa> [-o output]"
    [[ -f "$ipa_path" ]] || err "IPA not found: $ipa_path"

    # Make IPA path absolute
    if [[ "$ipa_path" != /* ]]; then
        ipa_path="$(pwd)/$ipa_path"
    fi

    # Load config for defaults
    load_resign_config

    # Use config values as fallback
    cert="${cert:-${WN_SIGN_IDENTITY:-}}"
    profile="${profile:-${WN_PROVISION_PROFILE:-}}"

    # Validate required params
    if [[ -z "$cert" ]]; then
        echo ""
        warn "No signing identity specified."
        echo ""
        echo "  Configure once:  wn resign --setup"
        echo "  Or specify:      wn resign app.ipa -c \"Apple Development: you@email.com\""
        echo ""
        echo "  Available identities:"
        security find-identity -v -p codesigning 2>/dev/null | head -10
        echo ""
        err "Signing identity required (-c or configure with: wn resign --setup)"
    fi

    if [[ -z "$profile" ]]; then
        echo ""
        warn "No provisioning profile specified."
        echo ""
        echo "  Configure once:  wn resign --setup"
        echo "  Or specify:      wn resign app.ipa -p ~/path/to/profile.mobileprovision"
        echo ""
        err "Provisioning profile required (-p or configure with: wn resign --setup)"
    fi

    [[ -f "$profile" ]] || err "Provisioning profile not found: $profile"

    # Default output path
    if [[ -z "$output_path" ]]; then
        local basename
        basename=$(basename "$ipa_path" .ipa)
        output_path="$(pwd)/${basename}_whiteneedle.ipa"
    elif [[ "$output_path" != /* ]]; then
        output_path="$(pwd)/$output_path"
    fi

    # Ensure framework is built (resign.sh needs it in payload)
    ensure_resign_payload

    # Build resign command
    local resign_script="$WN_ROOT/skills/whiteneedle-resign/bin/resign.sh"
    [[ -f "$resign_script" ]] || err "resign.sh not found at: $resign_script"

    local cmd=(
        "$resign_script"
        -i "$ipa_path"
        -c "$cert"
        -p "$profile"
        -o "$output_path"
    )

    if [[ -n "$bundle_id" ]]; then
        cmd+=(-b "$bundle_id")
    fi

    if [[ "$keep_extensions" == true ]]; then
        cmd+=(-e)
    fi

    info "Re-signing IPA with WhiteNeedle..."
    echo "  Input:  $ipa_path"
    echo "  Output: $output_path"
    echo "  Cert:   $cert"
    echo ""

    "${cmd[@]}"

    echo ""
    log "============================================"
    log "  Resign complete!"
    log "============================================"
    echo ""
    echo "  Output: $output_path"
    echo ""
    echo "  Install to device:"
    echo "    ios-deploy -b \"$output_path\""
    echo "    # or: ideviceinstaller -i \"$output_path\""
    echo ""
}

ensure_resign_payload() {
    local payload_dir="$WN_ROOT/skills/whiteneedle-resign/payload"
    local fw_in_payload="$payload_dir/WhiteNeedle.framework"

    if [[ -d "$fw_in_payload" && -f "$fw_in_payload/WhiteNeedle" ]]; then
        return 0
    fi

    # Try to copy from dist
    if [[ -d "$WN_FRAMEWORK" && -f "$WN_FRAMEWORK/WhiteNeedle" ]]; then
        mkdir -p "$payload_dir"
        rm -rf "$fw_in_payload"
        cp -R "$WN_FRAMEWORK" "$fw_in_payload"
        log "Copied framework to resign payload"
        return 0
    fi

    # Need to build
    info "Building framework for resign..."
    cmd_build
    mkdir -p "$payload_dir"
    rm -rf "$fw_in_payload"
    cp -R "$WN_FRAMEWORK" "$fw_in_payload"
}

load_resign_config() {
    WN_SIGN_IDENTITY=""
    WN_PROVISION_PROFILE=""

    if [[ -f "$WN_RESIGN_CONF" ]]; then
        source "$WN_RESIGN_CONF"
    fi
}

resign_setup() {
    ensure_config_dir
    echo ""
    echo -e "${BOLD}WhiteNeedle Resign Configuration${NC}"
    echo ""
    echo "This will save your default signing identity and provisioning profile"
    echo "so you don't need to specify them every time."
    echo ""

    # List available identities
    echo "Available signing identities:"
    echo ""
    security find-identity -v -p codesigning 2>/dev/null | grep -E "^\s+[0-9]" || true
    echo ""

    read -rp "Signing identity (full name or hash): " cert_input
    [[ -n "$cert_input" ]] || err "Signing identity cannot be empty"

    echo ""
    read -rp "Provisioning profile path (.mobileprovision): " profile_input
    [[ -n "$profile_input" ]] || err "Profile path cannot be empty"

    # Expand ~ in path
    profile_input="${profile_input/#\~/$HOME}"
    [[ -f "$profile_input" ]] || err "Profile not found: $profile_input"

    # Make profile path absolute
    if [[ "$profile_input" != /* ]]; then
        profile_input="$(cd "$(dirname "$profile_input")" && pwd)/$(basename "$profile_input")"
    fi

    cat > "$WN_RESIGN_CONF" <<EOF
# WhiteNeedle resign configuration
# Generated by: wn resign --setup
WN_SIGN_IDENTITY="$cert_input"
WN_PROVISION_PROFILE="$profile_input"
EOF

    echo ""
    log "Configuration saved to: $WN_RESIGN_CONF"
    echo ""
    echo "  You can now simply run:"
    echo "    wn resign MyApp.ipa"
    echo "    wn resign MyApp.ipa -o output.ipa"
    echo ""
}

resign_usage() {
    cat <<EOF
Usage: wn resign <ipa> [options]

Arguments:
  <ipa>                       Input IPA file path

Options:
  -o, --output <path>         Output IPA path (default: ./<name>_whiteneedle.ipa)
  -c, --cert <identity>       Signing identity (reads from ~/.whiteneedle/resign.conf)
  -p, --profile <path>        Provisioning profile (reads from ~/.whiteneedle/resign.conf)
  -b, --bundle-id <id>        Override bundle identifier
  -e, --keep-extensions       Keep app extensions (default: remove)
  --setup                     Interactive setup for signing defaults
  -h, --help                  Show this help

Examples:
  # First time: configure defaults
  wn resign --setup

  # Then just:
  wn resign MyApp.ipa
  wn resign MyApp.ipa -o ~/Desktop/output.ipa
  wn resign MyApp.ipa -b com.my.newid

  # Or specify everything inline:
  wn resign MyApp.ipa -c "Apple Development: dev@me.com" -p ~/dev.mobileprovision
EOF
    exit 0
}

# ============================================================================
# Main dispatch
# ============================================================================

usage() {
    cat <<EOF
${BOLD}wn${NC} — WhiteNeedle CLI

${BOLD}Usage:${NC}
  wn integrate <project-dir>    Integrate WhiteNeedle into an iOS project (CocoaPods)
  wn remove <project-dir>       Remove WhiteNeedle from a project
  wn status <project-dir>       Show integration status
  wn build                      Build WhiteNeedle framework and full dist
  wn update [opts] [project]    Recompile + install (framework & extension)
  wn resign <ipa> [-o output]   Inject WhiteNeedle into IPA and re-sign
  wn help                       Show this help

${BOLD}Quick Start:${NC}
  wn integrate ~/Projects/MyApp          # One-click pod integration
  wn update ~/Projects/MyApp             # Full update: framework + extension
  wn update --ios ~/Projects/MyApp       # Framework only + refresh pods
  wn update --ext                        # Extension only → Cursor + VS Code
  wn update --cursor                     # Extension to Cursor only
  wn resign App.ipa -o App_debug.ipa     # One-click IPA injection

${BOLD}Configuration:${NC}
  wn resign --setup              Save default signing identity & profile

${BOLD}Paths:${NC}
  WhiteNeedle root: $WN_ROOT
  Config dir:       $WN_CONFIG_DIR
EOF
    exit 0
}

case "${1:-help}" in
    integrate)
        shift
        [[ $# -ge 1 ]] || err "Usage: wn integrate <project-dir>"
        cmd_integrate "$@"
        ;;
    remove)
        shift
        [[ $# -ge 1 ]] || err "Usage: wn remove <project-dir>"
        cmd_remove "$@"
        ;;
    status)
        shift
        cmd_status "${1:-.}"
        ;;
    build)
        shift
        cmd_build
        ;;
    update)
        shift
        cmd_update "${1:-}"
        ;;
    resign)
        shift
        if [[ "${1:-}" == "--setup" ]]; then
            resign_setup
        elif [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
            resign_usage
        else
            cmd_resign "$@"
        fi
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        err "Unknown command: $1. Run 'wn help' for usage."
        ;;
esac
